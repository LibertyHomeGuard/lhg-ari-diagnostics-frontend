# Frontend environment variables
# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real keys

# EC2 Backend details (for reference)
EC2_IP=54.200.186.179
EC2_PORT=8001

# Backend API base URL
# LOCAL DEV: leave empty — Vite proxy forwards /api/* to EC2 (no CORS issues)
# PRODUCTION: set this in Amplify Console → Environment variables instead
VITE_API_URL=
