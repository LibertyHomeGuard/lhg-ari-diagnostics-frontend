# Frontend environment variables
# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real keys

# Backend API base URL (defaults to http://localhost:8001 if not set)
# Production: set this to your EC2 public URL e.g. http://ec2-xx-xx-xx-xx.compute-1.amazonaws.com:8001
VITE_API_URL=http://localhost:8001
