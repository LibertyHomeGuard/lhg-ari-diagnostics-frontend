# Frontend environment variables
# Copy this file to .env and fill in your values
# .env is git-ignored — never commit real keys

# ElevenLabs Conversational AI API key
# Get yours at: https://elevenlabs.io/app/settings/api-keys
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Backend API base URL (defaults to http://localhost:8001 if not set)
# Change this to your deployed API Gateway URL for production
# VITE_API_URL=http://localhost:8001
